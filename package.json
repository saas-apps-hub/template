{
  "name": "@template/source",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "backend": "nx run backend:serve",
    "marketing": "nx run marketing:serve",
    "ios": "nx run mobile:ios",
    "android": "nx run mobile:android",
    "clean": "./tools/scripts/clean.sh",
    "lint:check": "eslint \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,css}\"",
    "lint:fix": "eslint --fix \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,css}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,css,md}\"",
    "format:write": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,css,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.8.0",
    "@next/eslint-plugin-next": "~16.1.6",
    "@nx/esbuild": "22.7.0",
    "@nx/eslint": "22.7.0",
    "@nx/eslint-plugin": "22.7.0",
    "@nx/expo": "22.7.0",
    "@nx/jest": "22.7.0",
    "@nx/js": "22.7.0",
    "@nx/next": "22.7.0",
    "@nx/node": "22.7.0",
    "@nx/workspace": "22.7.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.7.10",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "~0.2.38",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "22.19.8",
    "autoprefixer": "10.4.13",
    "babel-jest": "^30.0.2",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-next": "~16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "lint-staged": "^16.2.7",
    "nx": "22.7.0",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "lint-staged": {
    "*/**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*/**/*.{ts,tsx,js,jsx,mjs,mts,cjs,cts}": [
      "eslint --fix"
    ],
    "*/**/*.{ts,tsx,mts}": [
      "bash -c 'pnpm nx affected -t typecheck'"
    ]
  }
}
