# This file is generated by Nx.
# Build the docker image with `npx nx docker:build backend`.
# Tip: Modify "docker:build" options in project.json to change docker build args.
#
# Run the container with `nx docker:run <image-name> -p 3000:3000`.
#
FROM docker.io/node:22-alpine

RUN corepack enable

WORKDIR /app

RUN addgroup --system apps && \
  adduser --system -G apps apps

COPY apps/backend/dist .

RUN chown -R apps:apps .

# You can remove this install step if you build with `--bundle` option.
# The bundled output will include external dependencies.

RUN pnpm install --prod

CMD [ "node", "main.js" ]
