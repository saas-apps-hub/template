{
  "name": "@template/marketing",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "marketing",
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "tsc -p tsconfig.json --emitDeclarationOnly --pretty"
          ],
          "cwd": "apps/marketing"
        }
      },
      "build-standalone": {
        "executor": "nx:run-commands",
        "options": {
          "command": "next build",
          "cwd": "apps/marketing",
          "env": {
            "NEXTJS_STANDALONE": "true"
          }
        },
        "cache": false,
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "{projectRoot}/.next/standalone",
          "{projectRoot}/.next/static"
        ],
        "configurations": {
          "production": {}
        }
      },
      "docker-build": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build-standalone"
        ],
        "options": {
          "command": "docker build -f apps/marketing/Dockerfile . -t {REGISTRY}/{OWNER}/{PROJECT}-marketing:${TAG}"
        }
      },
      "docker-push": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "docker-build"
        ],
        "options": {
          "command": "docker push {REGISTRY}/{OWNER}/{PROJECT}-marketing:${TAG}"
        }
      }
    }
  },
  "dependencies": {
    "@template/core": "workspace:*",
    "next": "~16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0"
  }
}
